# ====================================================================
# DAMRUBET BACKEND ENVIRONMENT CONFIGURATION TEMPLATE
# Copy this file to a new file named ".env" in the same folder and fill values
# ====================================================================

# 1. Server running port (Kounse port par server chalega, default: 5000)
PORT=5000

# 2. Frontend React Application URL (Is url ke alawa koi dusri website se request direct lock ho jayegi - CORS security)
# Local development ke liye ye usually http://localhost:3000 hota hai
FRONTEND_URL=http://localhost:3000

# 3. Supabase API Project URL
# Isko aap apne Supabase dashboard -> Project Settings -> API se le sakte hain
SUPABASE_URL=https://your-supabase-project.supabase.co

# 4. Supabase Secret Service Role Key (CRITICAL SECURITY KEY)
# WARNING: Ise kabhi bhi kisi client-side browser ya code me mat likhiyega!
# Ye key database security/RLS ko bypass karke admin requests handle karti hai.
SUPABASE_SERVICE_ROLE_KEY=your-secret-supabase-service-role-key-here

# 5. JWT Secret Key (Used for Admin Token signing)
# Kisi bhi random unique high-entropy string se replace karein
JWT_SECRET=super-secret-unique-jwt-key-for-damrubet

# 6. Admin Account Details
# Admin panel login email
ADMIN_EMAIL=admin@damrubet.com

# 7. Admin Encrypted Password Hash (Bcrypt-Hashed)
# Standard plain text nahi store karna hai. Use "node generateHash.js" to print one!
# Default of plain-text "admin12345" generated hash below:
ADMIN_PASSWORD_HASH="$2a$10$j80vJ8H/L2h.i4G8kQyqM.pZHeQscCq1bTjQd3k9kOitMIs0qQn1W"
